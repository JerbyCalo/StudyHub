rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — any authenticated user can read (needed for member lists);
    // only the owner can write their own document
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Subjects
    match /subjects/{subjectId} {
      // Any authenticated user can read subject metadata (needed for joinByCode query);
      // sensitive content (notes, files) is protected by subcollection rules below
      allow read:   if request.auth != null;
      // Any authenticated user can create a subject
      allow create: if request.auth != null;
      // Any authenticated user can update a subject (required for joinByCode,
      // which arrayUnions a new userId into memberIds before they're a member)
      allow update: if request.auth != null;
      // Only the owner can delete the subject
      allow delete: if request.auth.uid == resource.data.ownerId;

      // Notes subcollection
      match /notes/{noteId} {
        allow read: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow create: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow update: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow delete: if request.auth.uid == resource.data.authorId;
      }

      // Files subcollection
      match /files/{fileId} {
        allow read: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow create: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow update: if request.auth.uid in
          get(/databases/$(database)/documents/subjects/$(subjectId)).data.memberIds;
        allow delete: if request.auth.uid == resource.data.uploaderId;
      }
    }

  }
}
